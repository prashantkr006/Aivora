# ---------------------------------------------------------------
# AiVora — example environment file.
# Copy this file to ".env" and fill in real credentials.
# NEVER commit the real .env to version control.
# ---------------------------------------------------------------

# ----- Deployment public URLs (used by the Kite OAuth callback) -----
# Change these once — Zerodha's Redirect URL in developers.kite.trade
# must exactly match "${AIVORA_AUTH_URL}/kite/callback".
AIVORA_DASHBOARD_URL=https://app.aivora-self.com
AIVORA_AUTH_URL=https://auth.aivora-self.com

# ----- Encryption master key -----
# Fernet key that encrypts every user's broker credentials at rest.
# Generate ONCE with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LOSE THIS AND EVERY STORED KITE TOKEN BECOMES UNRECOVERABLE.
AIVORA_MASTER_KEY=

# ----- Path overrides (leave blank to use defaults from config.yaml) -----
AIVORA_DATA_DIR=
AIVORA_LOG_DIR=

# ----- Zerodha Kite Connect (for live daily data + orders) -----
# From https://developers.kite.trade/apps (Zerodha's developer console).
KITE_API_KEY=
KITE_API_SECRET=
# Filled automatically by the "Login to Kite" button in the dashboard.
KITE_ACCESS_TOKEN=
# Your Zerodha client id (BF1234 / AB0021 etc).  Optional here — the
# redirect flow fills it in on first login.
KITE_USER_ID=

# ----- Optional: TOTP auto-login (fully headless one-click) -----
# Only fill these in if you want the "Auto-login (TOTP)" button to
# work.  KITE_TOTP_SECRET is the SEED from your Zerodha 2FA QR code,
# NOT the current 6-digit code.  Leave blank to use the browser flow.
KITE_PASSWORD=
KITE_TOTP_SECRET=
